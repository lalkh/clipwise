# ─── Copy this file to .env and adjust ──────────────────────────────────────
#   macOS / Linux:   cp .env.example .env
#   Windows:         copy .env.example .env
# Or just run ./deploy.sh up  —  it auto-generates a sensible .env on first run.

# ─── Host-side ports ────────────────────────────────────────────────────────
# Change only if 8000 / 9001 clash with something else on your machine.
WEB_PORT=8000
MCP_PORT=9001

# ─── JianYing / CapCut draft directory ──────────────────────────────────────
# Leave blank to keep drafts project-local (./drafts).
# Set to your JianYing app's draft folder to have generated projects appear
# directly inside the desktop app.
#
#   macOS  (JianYing Pro):
#     JIANYING_DRAFT_DIR=${HOME}/Movies/JianyingPro/User Data/Projects/com.lveditor.draft
#     JIANYING_CACHE_DIR=${HOME}/Movies/JianyingPro/User Data/Cache/artistEffect
#
#   Windows (Docker Desktop on Windows, with backslashes converted to forward-slashes):
#     JIANYING_DRAFT_DIR=C:/Users/<YOUR_USERNAME>/AppData/Local/JianyingPro/User Data/Projects/com.lveditor.draft
#     JIANYING_CACHE_DIR=C:/Users/<YOUR_USERNAME>/AppData/Local/JianyingPro/User Data/Cache/artistEffect
#
#   Windows (WSL2):
#     JIANYING_DRAFT_DIR=/mnt/c/Users/<YOUR_USERNAME>/AppData/Local/JianyingPro/User Data/Projects/com.lveditor.draft
#     JIANYING_CACHE_DIR=/mnt/c/Users/<YOUR_USERNAME>/AppData/Local/JianyingPro/User Data/Cache/artistEffect
#
#   Linux:
#     JIANYING_DRAFT_DIR=${HOME}/.local/share/JianyingPro/User Data/Projects/com.lveditor.draft
#     JIANYING_CACHE_DIR=${HOME}/.local/share/JianyingPro/User Data/Cache/artistEffect

JIANYING_DRAFT_DIR=
JIANYING_CACHE_DIR=
